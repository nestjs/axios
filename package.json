{
  "name": "@nestjs/axios",
  "version": "4.0.1",
  "description": "Nest - modern, fast, powerful node.js web framework (@axios)",
  "author": "Kamil Mysliwiec",
  "license": "MIT",
  "url": "https://github.com/nestjs/axios#readme",
  "scripts": {
    "build": "rimraf -rf dist && tsc -p tsconfig.json",
    "format": "prettier --write \"{lib,test}/**/*.ts\"",
    "lint": "oxlint lib/",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "prepublish:next": "npm run build",
    "publish:next": "npm publish --access public --tag next",
    "test:e2e": "vitest run --config ./vitest.config.mts",
    "prerelease": "npm run build",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-angular": "20.5.3",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/testing": "11.1.19",
    "@types/node": "24.12.2",
    "axios": "1.16.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxlint": "^1.60.0",
    "prettier": "3.8.3",
    "reflect-metadata": "0.2.2",
    "release-it": "20.0.1",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "axios": "^1.3.1",
    "rxjs": "^7.0.0"
  },
  "lint-staged": {
    "**/*.{ts,json}": []
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs/axios"
  }
}
